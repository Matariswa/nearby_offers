rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'customer';
    }

    function isShopOwner() {
      return isSignedIn() && getUserRole() == 'shop_owner';
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isValidUserCreate() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.role in ['customer', 'shop_owner']
        && request.resource.data.isVerified is bool;
    }

    function isValidUserUpdate() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId) && isValidUserCreate();

      allow update: if (isOwner(userId) && isValidUserUpdate())
        || (isAdmin() && (request.resource.data.uid != request.auth.uid || request.resource.data.role == resource.data.role));

      allow delete: if false;
    }

    match /shops/{shopId} {
      allow read: if isAdmin()
        || (isShopOwner() && resource.data.ownerId == request.auth.uid)
        || (isSignedIn() && getUserRole() == 'customer' && resource.data.verified == true);

      allow create: if isAdmin()
        || (isShopOwner() && request.resource.data.ownerId == request.auth.uid);

      allow update: if isAdmin()
        || (isShopOwner() && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid)
        || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount', 'updatedAt']));

      allow delete: if isAdmin()
        || (isShopOwner() && resource.data.ownerId == request.auth.uid);
    }

    match /offers/{offerId} {
      allow read: if isAdmin()
        || (isShopOwner() && resource.data.ownerId == request.auth.uid)
        || (isSignedIn() && getUserRole() == 'customer' && resource.data.active == true);

      allow create: if isAdmin()
        || (isShopOwner() && request.resource.data.ownerId == request.auth.uid);

      allow update: if isAdmin()
        || (isShopOwner() && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid);

      allow delete: if isAdmin()
        || (isShopOwner() && resource.data.ownerId == request.auth.uid);
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /categories/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
